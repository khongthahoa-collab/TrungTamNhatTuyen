SECRET_KEY=change-me-to-a-long-random-string

# Supabase PostgreSQL
# Lấy từ Supabase dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Password for the auto-seeded dev admin account (username: nhattuyen). Falls back to a default if unset.
SEED_ADMIN_PASSWORD=

UPLOAD_FOLDER=uploads/documents
MAX_CONTENT_LENGTH=20971520
FLASK_ENV=development

# Zalo Integration (Phase 2)
ZALO_OA_ID=
ZALO_ACCESS_TOKEN=
ZALO_SECRET_KEY=
